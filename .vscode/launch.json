{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "java",
			"name": "QuickServe Cloud (profile: local)",
			"request": "launch",
			"mainClass": "com.qr.cloud.CloudApplication",
			"projectName": "cloud",
			"args": "--spring.profiles.active=local"
		},
		{
			"type": "java",
			"name": "QuickServe Edge (profile: local)",
			"request": "launch",
			"mainClass": "com.qr.edge.EdgeApplication",
			"projectName": "edge",
			"args": "--spring.profiles.active=local",
			"cwd": "${workspaceFolder}"
		},
		{
			"type": "dart",
			"name": "Flutter: edge_frontend (LAN telefon :57632)",
			"request": "launch",
			"cwd": "${workspaceFolder}/edge_frontend",
			"program": "lib/main.dart",
			"deviceId": "web-server",
			"toolArgs": ["--web-port=57632", "--web-hostname=0.0.0.0"]
		},
		{
			"type": "dart",
			"name": "Flutter: edge_frontend (Chrome yerel)",
			"request": "launch",
			"cwd": "${workspaceFolder}/edge_frontend",
			"program": "lib/main.dart",
			"deviceId": "chrome",
			"toolArgs": ["--web-port=57632"]
		},
		{
			"type": "dart",
			"name": "Flutter: cloud_frontend (web :57633)",
			"request": "launch",
			"cwd": "${workspaceFolder}/cloud_frontend",
			"program": "lib/main.dart",
			"deviceId": "chrome",
			"toolArgs": ["--web-port=57633"]
		}
	]
}
