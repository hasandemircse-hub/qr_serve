{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickserve.local/schemas/floor_layout.schema.json",
  "title": "QuickServe FloorLayout",
  "description": "Restoran salon düzeni: katlar, masa grupları, şekil ve konum. Edge WebSocket ile terminallere yayınlanır.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "restaurantId", "floors"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Şema sürümü; uyumsuz sürümde istemci reddetmeli."
    },
    "restaurantId": {
      "type": "string",
      "format": "uuid",
      "description": "Restoran kimliği (UUID v4)."
    },
    "floors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/floor" }
    }
  },
  "$defs": {
    "floor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floorIndex", "label", "tables"],
      "properties": {
        "floorIndex": {
          "type": "integer",
          "minimum": 0,
          "description": "Kat indeksi (0 = zemin kat)."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Kat adı (ör. Zemin, 1. Kat)."
        },
        "tables": {
          "type": "array",
          "items": { "$ref": "#/$defs/tableLayout" }
        }
      }
    },
    "tableLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tableId",
        "label",
        "shape",
        "x",
        "y",
        "width",
        "height",
        "floorIndex",
        "groupId",
        "availabilityStatus"
      ],
      "properties": {
        "tableId": {
          "type": "string",
          "format": "uuid",
          "description": "dining_tables.id ile aynı UUID."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Masa görünen adı."
        },
        "shape": {
          "type": "string",
          "enum": ["SQUARE", "ROUND"],
          "description": "Çizim şekli (CustomPainter)."
        },
        "x": {
          "type": "number",
          "description": "Salon düzleminde X (mantıksal piksel veya cm; tüm istemciler aynı birimi kullanır)."
        },
        "y": {
          "type": "number",
          "description": "Salon düzleminde Y."
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Dikdörtgen sınırlayıcı genişlik (ROUND için çap kutusu)."
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Dikdörtgen sınırlayıcı yükseklik."
        },
        "floorIndex": {
          "type": "integer",
          "minimum": 0,
          "description": "Üst floor ile aynı olmalı; çift doğrulama için."
        },
        "groupId": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "Masa grubu (ör. teras A); null = grupsuz."
        },
        "availabilityStatus": {
          "type": "string",
          "enum": ["EMPTY", "OCCUPIED", "RESERVED"],
          "description": "Masa durumu: boş, dolu, rezerve."
        },
        "seatCount": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "İsteğe bağlı kapasite."
        },
        "zone": {
          "type": ["string", "null"],
          "maxLength": 64,
          "description": "İsteğe bağlı bölge etiketi."
        },
        "rotation": {
          "type": "number",
          "description": "Masa çizimi için derece cinsinden saat yönü dönüş (varsayılan 0)."
        }
      }
    }
  }
}
