# QuickServe Cloud deploy environment
# cp .env.example .env  ve değerleri doldur

# --- Caddy / domain ---
# Cloud için public hostname. Caddy bunu Let's Encrypt ile TLS yapacak.
#
# Seçenek A) Kendi domain'in: cloud.example.com (DNS A kaydı VPS IP'sine)
# Seçenek B) Domainsiz test: <vps-ip>.nip.io   örn. 185.123.45.67.nip.io
#            (nip.io herhangi bir IP için anında DNS çözümler;
#             Let's Encrypt nip.io subdomain'i için sertifika verir)
CLOUD_HOSTNAME=cloud.example.com

# Spring/Cloud bu URL'yi QR PDF, /r/ redirect ve linklerde kullanır.
# CLOUD_HOSTNAME ile aynı olmalı, https:// önekiyle.
QUICKSERVE_PUBLIC_CLOUD_URL=https://cloud.example.com

# Misafir Flutter Web tabanı (varsayılan: aynı host, /#/guest/qr Flutter hash route)
# Boş bırakırsanız PUBLIC_CLOUD_URL kullanılır.
QUICKSERVE_GUEST_WEB_BASE_URL=

# --- PostgreSQL ---
POSTGRES_DB=quickserve_cloud
POSTGRES_USER=quickserve
POSTGRES_PASSWORD=changeme_strong_password

# --- Güvenlik ---
# JWT secret: en az 32 byte. Üretmek için:
#   openssl rand -base64 48
QUICKSERVE_JWT_SECRET=changeme_min_32_bytes_random_string_aaaaaaaaaaaaaa

# --- İlk kurulum bootstrap (idempotent) ---
# enabled=true iken Cloud her açılışta süperadmin var mı diye bakar:
#   - Yoksa: aşağıdaki değerlerle bir süperadmin (+ opsiyonel restoran) yaratır.
#   - Varsa: hiçbir şey yapmaz, log'a "skipping" yazar.
# Yani bu env değerlerini bırakmanın bir zararı yok; sadece ilk açılışta etki eder.
QUICKSERVE_BOOTSTRAP_SUPERADMIN_ENABLED=true
QUICKSERVE_BOOTSTRAP_SUPERADMIN_EMAIL=admin@quickserve.test
QUICKSERVE_BOOTSTRAP_SUPERADMIN_PASSWORD=ChangeMe123!
QUICKSERVE_BOOTSTRAP_SUPERADMIN_DISPLAY_NAME=Süper Yönetici
# Boş bırakırsanız sadece süperadmin oluşur, restoran oluşturulmaz.
QUICKSERVE_BOOTSTRAP_RESTAURANT_NAME=Test Restoran

# --- Edge izleme ayarları ---
QUICKSERVE_ADMIN_EDGE_ONLINE_THRESHOLD_SECONDS=180
QUICKSERVE_GUEST_EDGE_PROXY_TIMEOUT_SECONDS=15
