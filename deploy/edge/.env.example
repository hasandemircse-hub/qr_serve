# QuickServe Edge deploy environment
# cp .env.example .env  ve değerleri doldur

# --- Caddy / LAN ---
# Personelin Edge'e LAN'dan eriştiği DNS adı (opsiyonel; yoksa IP ile gir).
EDGE_LAN_HOSTNAME=edge.local

# --- Cloud bağlantısı ---
# Edge -> Cloud çıkışı (hello, sync push, bootstrap)
QUICKSERVE_CLOUD_BASE_URL=https://cloud.example.com
# QR PDF ve link üretimi için Cloud public adresi
QUICKSERVE_PUBLIC_CLOUD_URL=https://cloud.example.com

# --- Edge kimliği ---
# Restoran başına sabit UUID. Üretmek için:
#   uuidgen
QUICKSERVE_EDGE_ID=00000000-0000-0000-0000-000000000000
QUICKSERVE_RESTAURANT_ID=11111111-1111-1111-1111-111111111111

# --- Public Edge URL ---
# Hello payload'una yazılır; Cloud BFF buradan Edge'e proxy yapar.
# - QUICK tunnel (test): docker compose ilk açıldığında boş bırak,
#   `deploy/scripts/edge-quick-tunnel.sh` otomatik doldurur.
# - NAMED tunnel (üretim): Cloudflare panelinde tanımladığın hostname.
QUICKSERVE_PUBLIC_EDGE_URL=

# --- Cloudflare named tunnel için (opsiyonel) ---
# Quick tunnel kullanıyorsan boş bırak. Named tunnel için docker-compose.yml
# içindeki command'i değiştir + bu token'ı doldur.
CLOUDFLARED_TUNNEL_TOKEN=

# --- PostgreSQL ---
POSTGRES_DB=quickserve_edge
POSTGRES_USER=quickserve
POSTGRES_PASSWORD=changeme_strong_password

# --- Güvenlik ---
# Bu Edge ile Cloud arasında aynı secret kullanılmalı mı? Hayır — her ikisi de JWT'leri
# kendi domain'i için imzalar. Bu Edge için bağımsız bir secret.
#   openssl rand -base64 48
QUICKSERVE_JWT_SECRET=changeme_min_32_bytes_random_string_aaaaaaaaaaaaaa

# --- Misafir lab (DEV/UAT testi için) ---
# Üretimde false bırakın.
QUICKSERVE_GUEST_LAB_ENABLED=false

# --- Resim upload limiti (byte) ---
QUICKSERVE_MEDIA_MAX_IMAGE_BYTES=5242880
