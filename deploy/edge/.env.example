# QuickServe Edge deploy environment
# cp .env.example .env  ve değerleri doldur

# --- Image tag ---
# Edge'e tar.gz olarak gönderilen `quickserve/edge:<TAG>` ve
# `quickserve/edge-caddy:<TAG>` imajlarının tag'i. Build sırasında
# `./deploy/scripts/build-edge-images.sh --tag v0.1.0` ile ne kullandıysan
# burada da aynısı olmalı. Mac'te local geliştiriciyseniz default "local" yeterli.
EDGE_TAG=local

# --- Caddy / LAN ---
# Personelin Edge'e LAN'dan eriştiği DNS adı (opsiyonel; yoksa IP ile gir).
EDGE_LAN_HOSTNAME=edge.local

# --- Cloud bağlantısı ---
# Edge -> Cloud çıkışı (hello, sync push, bootstrap)
QUICKSERVE_CLOUD_BASE_URL=https://cloud.example.com
# QR PDF ve link üretimi için Cloud public adresi
QUICKSERVE_PUBLIC_CLOUD_URL=https://cloud.example.com

# --- Edge kimliği ---
# Restoran başına sabit UUID. Üretmek için:
#   uuidgen
QUICKSERVE_EDGE_ID=00000000-0000-0000-0000-000000000000
QUICKSERVE_RESTAURANT_ID=11111111-1111-1111-1111-111111111111

# --- Public Edge URL ---
# Hello payload'una yazılır; Cloud BFF buradan Edge'e proxy yapar.
# NAMED tunnel (üretim): Cloudflare panelinde tanımladığın hostname (örn.
#   https://edge.qrserve.co). Restart-proof; her zaman aynı kalır.
# QUICK tunnel'a geri dönmek istersen (test, domain yok): docker-compose.yml
# içindeki cloudflared service'ini Quick mode'a çevir + .env'i otomasyon script'ine bırak.
QUICKSERVE_PUBLIC_EDGE_URL=https://edge.example.com

# --- Cloudflare named tunnel token ---
# Zero Trust dashboard > Networks > Tunnels > <tunnel-adi> > Configure > Token.
# Çok hassas: repo'ya commit'leme, log'lama, paylaşma.
# Sızdırırsan: panelden delete + new connector + token yenile.
CLOUDFLARED_TUNNEL_TOKEN=eyJh...replace_with_real_token...

# --- PostgreSQL ---
POSTGRES_DB=quickserve_edge
POSTGRES_USER=quickserve
POSTGRES_PASSWORD=changeme_strong_password

# --- Güvenlik ---
# Bu Edge ile Cloud arasında aynı secret kullanılmalı mı? Hayır — her ikisi de JWT'leri
# kendi domain'i için imzalar. Bu Edge için bağımsız bir secret.
#   openssl rand -base64 48
QUICKSERVE_JWT_SECRET=changeme_min_32_bytes_random_string_aaaaaaaaaaaaaa

# Edge ↔ Cloud sync paylaşılan secret. Cloud .env'indeki
# QUICKSERVE_SYNC_SHARED_SECRET ile aynı olmalı. Boş bırakırsan Edge başlığı
# göndermez; Cloud da o durumda kapısını açık bırakır (geçiş kolaylığı, üretimde DOLDUR).
#   openssl rand -base64 48
QUICKSERVE_SYNC_SHARED_SECRET=

# --- Misafir lab (DEV/UAT testi için) ---
# Üretimde false bırakın.
QUICKSERVE_GUEST_LAB_ENABLED=false

# --- Resim upload limiti (byte) ---
QUICKSERVE_MEDIA_MAX_IMAGE_BYTES=5242880
